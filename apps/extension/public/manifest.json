{
  "manifest_version": 3,
  "name": "fenshot — read the chessboard on this page",
  "version": "0.1.0",
  "description": "One click reads the chess position on the current page, entirely on your device, and opens it for analysis. Nothing is uploaded.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Read the chessboard on this page",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fenshot@coachess.app",
      "strict_min_version": "128.0"
    }
  }
}
